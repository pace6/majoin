# majoin API environment — copy to the deploy dir on the VPS as `.env`.
# systemd reads it via EnvironmentFile= (see majoin.service); deploy.sh
# sources it so alembic gets DATABASE_URL. Never commit the real .env.

# Postgres DSN — same DB password as Synapse's homeserver.yaml.
DATABASE_URL=postgresql://synapse:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/synapse

# Admin key for the sticker register/delete endpoints.
STICKER_ADMIN_KEY=CHANGE_ME_ADMIN_KEY

# Optional — Slack incoming-webhook for deploy notifications. Silent if unset.
#SLACK_DEPLOY_WEBHOOK_URL=
