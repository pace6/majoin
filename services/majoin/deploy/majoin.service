[Unit]
Description=majoin backend API
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/majoin
Environment=STICKER_ADMIN_KEY=CHANGE_ME_ADMIN_KEY
Environment=DATABASE_URL=postgresql://synapse:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/synapse
# uv resolves the venv from .venv/ created by `uv sync`.
ExecStart=/usr/local/bin/uv run uvicorn main:app --host 127.0.0.1 --port 8410
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
