# Copy to .env and fill in. The bot reads these from the environment.

# Homeserver base URL.
MATRIX_HOMESERVER=https://chat.tokens2.io

# The bot's own account — register it first (see README).
BOT_USER_ID=@weather:chat.tokens2.io
BOT_PASSWORD=change-me

# Shared secret between the Synapse register hook and this webhook.
# Must match `token` in the homeserver.yaml modules config.
HOOK_TOKEN=change-me-too

# Port the /hooks/new-user webhook listens on.
HOOK_PORT=8470

# Hour of day (Asia/Bangkok, 0-23) for the morning broadcast.
MORNING_HOUR=7
